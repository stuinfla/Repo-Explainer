{ "dimension": "usage", "query": "What does each agent's SYSTEM_PROMPT instruct it to do, and what model tier runs each one?", "mustContain": ["SYSTEM_PROMPT", "TIER", "sonnet", "haiku"] }
{ "dimension": "usage", "query": "How do I drive the CLI from code? What is the signature of the dispatcher and how do the tests call it?", "mustContain": ["run", "argv", "doctor", "exit code"] }
