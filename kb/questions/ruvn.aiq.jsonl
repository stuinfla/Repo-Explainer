{ "dimension": "capabilities", "query": "What can ruvn do? List the pipeline stages and what each agent produces.", "mustContain": ["scout", "source-grader", "synthesizer", "fact-checker", "citer", "A/B/C/D"] }
{ "dimension": "capabilities", "query": "How does ruvn grade sources — what do grades A, B, C, and D mean, and which grades is the synthesizer allowed to use?", "mustContain": ["primary source", "tertiary", "discard", "grade A and B"] }
{ "dimension": "capabilities", "query": "Which CLI commands does ruvn expose and what does each do?", "mustContain": ["init", "doctor", "--version", "--help"] }
