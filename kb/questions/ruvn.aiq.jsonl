// scripts/openrouter-validate.mjs, __tests__/*). mustContain = anchors used only by the --dry proxy.
{ "dimension": "onboarding", "query": "I just got this repo. How do I install, run, and test ruvn from scratch, including running it with no install? Give me the exact commands.", "mustContain": ["npm i -g @ruvnet/ruvn", "ruvn init", "ruvn doctor", "npx @ruvnet/ruvn", "npm test"] }
{ "dimension": "onboarding", "query": "What is the fastest way to see ruvn actually do something, and what does `ruvn doctor` check?", "mustContain": ["ruvn doctor", "ruvn init", "kernel", "host adapter"] }
{ "dimension": "onboarding", "query": "How do I validate ruvn end-to-end against a real model, and what env var do I need?", "mustContain": ["validate:openrouter", "OPENROUTER_API_KEY", "agents"] }
{ "dimension": "what-it-is", "query": "What is ruvn and what specific problem does it solve for me?", "mustContain": ["research", "graded", "cited", "dossier", "evidence"] }
{ "dimension": "what-it-is", "query": "Why would I use ruvn instead of just asking an AI a research question directly? What does it give me back?", "mustContain": ["grades every source", "cited", "dossier", "bibliography"] }
